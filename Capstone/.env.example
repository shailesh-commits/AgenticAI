# ── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── News / Market Data ────────────────────────────────────────────────────────
# Optional: leave blank to use mock data (mock_mode: true in config.yaml)
NEWSAPI_KEY=

# ── Observability (optional) ──────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── State store ───────────────────────────────────────────────────────────────
# SQLite (default for prototype — no external service needed)
STATE_DB_PATH=./data/state.db

# Redis (uncomment for production path)
# REDIS_URL=redis://localhost:6379/0

# PostgreSQL (uncomment for production path)
# POSTGRESQL_URL=postgresql+asyncpg://user:pass@localhost:5432/wam_platform

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
